generated_vmems_key1/
generated_vmems_key2/
vcds/
# Gate-level VCD files (tens to hundreds of MB each)
*.vcd
# Joules time-series power traces
*.data
# Plots generated by Result/plot.py
*.svg

# ── Software build artefacts (regenerated by parsemake.py / make) ─────────────
*.o
*.elf
*.bin
*.dis
# SDF backup/temp files created by some EDA tools
*.sdf.X
# Compiled vmem in Software/ (build output; Result/vmem1.vmem sample is kept)
Get_Traces/Software/hello_test.vmem

# ── OS / editor clutter ───────────────────────────────────────────────────────
.DS_Store
__pycache__/
*.pyc
.ipynb_checkpoints/
